# Required: Anthropic API key for the AI chatbot and product import script
ANTHROPIC_API_KEY=sk-ant-...

# Public site URL (used for QR code generation and OpenGraph meta tags)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Amazon storefront URL (shown in return instructions)
NEXT_PUBLIC_AMAZON_STOREFRONT_URL=https://www.amazon.com/stores/YourBrand/page/XXXXXXXXX

# Support email (shown in website return instructions)
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# Return portal URL (shown in website return instructions)
NEXT_PUBLIC_RETURN_PORTAL_URL=https://yourdomain.com/returns

# Admin product manager (required for /products/manage)
ADMIN_PASSWORD=your-admin-password
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=product-landing-pages
GITHUB_BRANCH=main
